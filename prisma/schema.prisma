// LootLoom — Production Prisma Schema
// Real database models for the production application.
// No fake data. All data flows: Database → API → Frontend → UI.

generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ============================================================
// USER DOMAIN
// ============================================================

model User {
  id          String   @id @default(cuid())
  googleId    String?  @unique
  email       String   @unique
  password    String?
  username    String?  @unique
  name        String
  avatar      String?
  role        String   @default("USER") // USER | CEO | ADMIN
  status      String   @default("ACTIVE") // ACTIVE | SUSPENDED | BANNED
  emailVerified    Boolean   @default(false)
  passwordChangedAt DateTime?
  lastLoginAt       DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  profile         UserProfile?
  wallet          Wallet?
  transactions    Transaction[]
  adEvents        AdEvent[]
  redeemRequests  RedeemRequest[]
  notifications   Notification[]
  supportTickets  SupportTicket[]
  auditLogs       AuditLog[]       @relation("AuditActor")
  feedback        UserFeedback[]   @relation("UserFeedback")
  referralCode    ReferralCode?
  referralsGiven  Referral[]       @relation("Referrer")
  referralsUsed   Referral[]       @relation("Referee")
  userMissions    UserMission[]
  missionLogs     MissionLog[]

  @@index([email])
  @@index([role])
  @@index([status])
  @@index([createdAt])
}

model UserProfile {
  id        String  @id @default(cuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String?
  lastName  String?
  country   String?
  timezone  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ============================================================
// REFERRAL DOMAIN
// ============================================================

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String   @unique
  createdAt DateTime @default(now())

  @@index([code])
}

model Referral {
  id          String   @id @default(cuid())
  referrerId  String
  referrer    User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  refereeId   String   @unique
  referee     User     @relation("Referee", fields: [refereeId], references: [id], onDelete: Cascade)
  rewardGiven Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([referrerId])
  @@index([refereeId])
}

// ============================================================
// MISSION DOMAIN
// ============================================================

model Mission {
  id            String   @id @default(cuid())
  key           String   @unique // DAILY_LOGIN | WATCH_ADS | REFERRAL | WEEKLY_BONUS | MILESTONE
  name          String
  description   String?
  rewardCoins   Int      @default(0)
  requirement   Int      @default(1) // number of actions required
  cooldownHours Int?     // hours before repeatable (null = one-time)
  status        String   @default("ACTIVE") // ACTIVE | DISABLED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  userMissions UserMission[]
  missionLogs  MissionLog[]
}

model UserMission {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  missionId  String
  mission    Mission  @relation(fields: [missionId], references: [id])
  progress   Int      @default(0)
  completed  Boolean  @default(false)
  claimedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, missionId])
  @@index([userId])
}

model MissionLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  missionId String
  mission   Mission  @relation(fields: [missionId], references: [id])
  reward    Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// ============================================================
// WALLET DOMAIN — one wallet per user, all changes via ledger
// ============================================================

model Wallet {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coinBalance  Int      @default(0)
  totalEarned  Int      @default(0)
  totalSpent   Int      @default(0)
  status       String   @default("ACTIVE") // ACTIVE | FROZEN
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  transactions    Transaction[]
  redeemRequests  RedeemRequest[]

  @@index([userId])
}

// ============================================================
// TRANSACTION LEDGER — immutable, every balance change recorded
// ============================================================

model Transaction {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletId       String
  wallet         Wallet   @relation(fields: [walletId], references: [id])
  type           String   // AD_REWARD | MISSION_REWARD | REFERRAL_BONUS | REDEEM | ADMIN_ADJUSTMENT | REFUND
  amount         Int      // positive = credit, negative = debit
  balanceBefore  Int
  balanceAfter   Int
  referenceId    String?
  description    String?
  status         String   @default("COMPLETED") // COMPLETED | PENDING | FAILED
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([walletId])
  @@index([type])
  @@index([createdAt])
  @@index([userId, type])
  @@index([userId, status])
  @@index([userId, createdAt])
}

// ============================================================
// ADVERTISEMENT DOMAIN
// ============================================================

model AdEvent {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerKey     String?  @default("waterfall") // which provider served this ad
  adType          String   // REWARDED_VIDEO | INTERSTITIAL | BANNER
  rewardAmount    Int      @default(0)
  status          String   @default("STARTED") // STARTED | COMPLETED | FAILED | VERIFIED
  verificationId  String?
  errorCode       String?  // provider error code on failure
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([providerKey])
}

model AdProvider {
  id            String   @id @default(cuid())
  key           String   @unique           // monetag, a-ads, yllix, etc.
  name          String
  enabled       Boolean  @default(true)
  priority      Int      @default(0)       // lower = higher priority
  publisherId   String?  // provider-specific
  zoneId        String?  // provider-specific
  apiKey        String?  // provider-specific
  rewardAmount  Int      @default(25)
  dailyLimit    Int      @default(100)
  timeoutMs     Int      @default(8000)
  status        String   @default("ACTIVE") // ACTIVE | DISABLED | ERROR
  successRate   Float    @default(0.0)
  fillRate      Float    @default(0.0)
  todayRevenue  Int      @default(0)
  totalRevenue  Int      @default(0)
  completedAds  Int      @default(0)
  failedAds     Int      @default(0)
  lastErrorAt   DateTime?
  lastSuccessAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([enabled])
  @@index([priority])
  @@index([status])
}

// ============================================================
// REWARD DOMAIN
// ============================================================

model Reward {
  id          String   @id @default(cuid())
  name        String
  description String?
  image       String?
  coinCost    Int
  category    String   // UPI
  stock       Int      @default(-1) // -1 = unlimited
  status      String   @default("ACTIVE") // ACTIVE | DISABLED | SOLD_OUT
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  redeemRequests RedeemRequest[]

  @@index([category])
  @@index([status])
  @@index([coinCost])
}

// ============================================================
// REDEEM DOMAIN
// ============================================================

model RedeemRequest {
  id             String   @id @default(cuid())
  redeemId       String   @unique @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rewardId       String
  reward         Reward   @relation(fields: [rewardId], references: [id])
  walletId       String
  wallet         Wallet   @relation(fields: [walletId], references: [id])
  coinsUsed      Int
  paymentMethod  String?
  paymentDetails String?
  userNote       String?  // optional message from user
  status         String   @default("PENDING") // PENDING | APPROVED | PROCESSING | PAID | REJECTED | COMPLETED | CANCELLED | REFUNDED
  adminNote      String?
  transactionId  String?  // CEO enters payment transaction ID when marking PAID
  paymentDate    DateTime? // date of actual payment
  processedBy    String?
  processedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([status, createdAt])
  @@index([createdAt])
  @@index([redeemId])
}

// ============================================================
// NOTIFICATION DOMAIN
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   // WALLET | REWARD | REDEEM | SUPPORT | SECURITY | SYSTEM | MISSION
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([type])
}

model VerificationToken {
  id         String   @id @default(cuid())
  identifier String   // email or userId
  token      String   @unique
  type       String   // EMAIL_VERIFY | PASSWORD_RESET
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([identifier])
  @@index([token])
  @@index([expiresAt])
}

// ============================================================
// SUPPORT DOMAIN
// ============================================================

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String
  category  String
  status    String   @default("OPEN") // OPEN | PENDING | RESOLVED | CLOSED
  priority  String   @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages SupportMessage[]

  @@index([userId])
  @@index([status])
  @@index([status, createdAt])
}

model SupportMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId  String
  message   String
  createdAt DateTime @default(now())

  @@index([ticketId])
  @@index([senderId])
  @@index([ticketId, createdAt])
}

// ============================================================
// AUDIT LOG — every important action recorded
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  actor     User     @relation("AuditActor", fields: [actorId], references: [id])
  action    String   // USER_REGISTERED | USER_LOGIN | WALLET_CREDIT | WALLET_DEBIT | REDEEM_REQUESTED | REDEEM_APPROVED | REDEEM_REJECTED | REDEEM_REFUNDED | etc.
  targetId  String?
  metadata  String?
  createdAt DateTime @default(now())

  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}

// ============================================================
// CAMPAIGN DOMAIN — CEO-controlled earning campaigns
// ============================================================

model Campaign {
  id            String   @id @default(cuid())
  name          String
  description   String?
  type          String   @default("EARNING_MULTIPLIER") // EARNING_MULTIPLIER | BONUS | EVENT
  multiplier    Float    @default(1.0)
  startDate     DateTime
  endDate       DateTime
  targetUsers   String   @default("ALL") // ALL | NEW | ACTIVE | INACTIVE
  status        String   @default("SCHEDULED") // SCHEDULED | ACTIVE | PAUSED | COMPLETED | CANCELLED
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([startDate])
}

// ============================================================
// FEATURE FLAGS — CEO-controlled feature experiments
// ============================================================

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(false)
  rollout     Float    @default(0.0) // 0.0 to 1.0 — percentage of users
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// PLATFORM CONFIG — CEO-adjustable settings without code changes
// ============================================================

model PlatformConfig {
  id    String @id @default(cuid())
  key   String @unique
  value String
  label String?
  type  String @default("STRING") // STRING | NUMBER | BOOLEAN
}

// ============================================================
// USER FEEDBACK — ratings, suggestions, support feedback
// ============================================================

model UserFeedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserFeedback", fields: [userId], references: [id], onDelete: Cascade)
  category  String   // RATING | SUGGESTION | BUG | FEATURE_REQUEST
  message   String
  rating    Int?     // 1-5 stars
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([category])
  @@index([createdAt])
}
